extends layout

block content
  .row
    .col-12
      h1.site-title Add review

  .row
    .col-md-8
      form
        .mb-3
          label.form-label(for='name') Name
          input.form-control(type='text', id='name')

        .mb-3
          label.form-label(for='rating') Rating
          select.form-select(id='rating')
            option 5
            option 4
            option 3
            option 2
            option 1

        .mb-3
          label.form-label(for='review') Review
          textarea.form-control(id='review', rows='5')

        button.btn.btn-light(type='submit') Submit