extends layout

block content
  h1= title
  p Bienvenido a #{title}

  p Esta es la página principal de la aplicación.

  a(href="/about") Ir a la página About
  .container-fluid.bg-success.text-white.min-vh-100.d-flex.align-items-center
    .container
      .row.align-items-center
        .col-md-6
          h1.display-3 Express
          p.lead Welcome to Express

        .col-md-6.text-center
          img.img-fluid(src="https://media.giphy.com/media/3o7aD2saalBwwftBIY/giphy.gif")